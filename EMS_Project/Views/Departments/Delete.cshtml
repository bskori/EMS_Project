@model EMS_Project.Models.Department

@{
    ViewBag.Title = "Delete";
}

<div class="container">
    <div class="row">
        <div class="col-md-offset-3 col-md-6">
            <h2 class="text-muted"  >Delete</h2>

            <h3 class="text-danger">Are you sure you want to delete this?</h3>
            <div>
                <h4>Department</h4>
                <hr />
                <dl class="dl-horizontal">
                    <dt>
                        @Html.DisplayNameFor(model => model.DeptName)
                    </dt>

                    <dd>
                        @Html.DisplayFor(model => model.DeptName)
                    </dd>

                </dl>

                @using (Html.BeginForm())
