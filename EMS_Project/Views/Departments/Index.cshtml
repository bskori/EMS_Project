@model IEnumerable<EMS_Project.Models.Department>

@{
    ViewBag.Title = "Department List";
}

<div class="container" style="margin-top:2rem">
    <div class="row">
        <div class="col-md-offset-3 col-md-6">
            <h2 class="text-center text-primary">Department List</h2>

            <p>
                @Html.ActionLink("Add New Department", "Create",null, new { @class="btn btn-success"})
            </p>
            <table class="table table-bordered table-striped table-hover text-center">
                <tr >
                    <th class="text-center">
                        Department
                    </th>
                    <th class="text-center">Actions</th>
                </tr>

                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.DeptName)
                        </td>
                        <td>
                            @Html.ActionLink("Edit", "Edit", new { id = item.DeptId }, new { @class="btn btn-primary"}) 
                            @Html.ActionLink("Delete", "Delete", new { id = item.DeptId }, new { @class ="btn btn-danger"})
                        </td>
                    </tr>
                }

            </table>

        </div>
    </div>
</div>